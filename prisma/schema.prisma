// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  ADMIN
  OPERATOR
  MANAGEMENT
}

enum OrderStatus {
  PENDING_PAYMENT
  WAITING_APPROVAL
  IN_PRODUCTION
  READY_FOR_PICKUP
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ProductionStatus {
  QUEUE
  PRINTING
  FINISHING
  QC_CHECK
  DONE
}

enum QCStatus {
  PASSED
  REJECTED
  NEEDS_REWORK
}

enum InventoryLogType {
  IN
  OUT
}

// TAMBAHAN: Status Mesin
enum MachineStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
}

// ================= MODELS =================

// 1. PENGGUNA & AUTENTIKASI (Tetap milikmu)
model User {
  id            String           @id @default(uuid())
  name          String
  email         String           @unique
  passwordHash  String
  phone         String?
  role          Role             @default(CUSTOMER)
  
  orders        Order[]          @relation("CustomerOrders")
  jobsHandled   ProductionJob[]  @relation("OperatorJobs")
  qcInspections QualityControl[] @relation("QCInspector")
  notifications Notification[]

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

// 2. KATALOG & PRODUK
model Category {
  id        String    @id @default(uuid())
  name      String
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String    @id @default(uuid())
  categoryId  String
  name        String
  description String?
  basePrice   Float
  unit        String    
  
  category    Category  @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  
  // TAMBAHAN: Relasi ke bahan baku (Resep/BOM) untuk pemotongan otomatis
  materials   ProductMaterial[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// TAMBAHAN: Tabel Perantara Produk & Material (Bill of Materials)
model ProductMaterial {
  id           String   @id @default(uuid())
  productId    String
  materialId   String
  qtyNeeded      Float    // Berapa banyak bahan ini dipakai untuk 1 unit produk
  
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  material     Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
}

// 3. INVENTARIS & BAHAN BAKU
// TAMBAHAN: Sesuai proposal "integrasi dengan supplier"
model Supplier {
  id        String     @id @default(uuid())
  name      String
  contact   String
  materials Material[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Material {
  id         String         @id @default(uuid())
  name       String
  stockQty   Float          @default(0)
  minStock   Float          @default(10)
  unit       String         
  
  supplierId String?
  supplier   Supplier?      @relation(fields: [supplierId], references: [id])
  
  logs             InventoryLog[]
  productMaterials ProductMaterial[] // Relasi balik dari tabel resep

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model InventoryLog {
  id         String           @id @default(uuid())
  materialId String
  type       InventoryLogType
  qty        Float
  notes      String?          
  
  material   Material         @relation(fields: [materialId], references: [id])

  createdAt  DateTime         @default(now())
}

// 4. PESANAN & PEMBAYARAN
model Order {
  id          String      @id @default(uuid())
  orderNumber String      @unique 
  customerId  String
  status      OrderStatus @default(PENDING_PAYMENT)
  totalAmount Float
  deadline    DateTime?
  
  customer    User        @relation("CustomerOrders", fields: [customerId], references: [id])
  items       OrderItem[]
  payment     Payment?    
  
  // TAMBAHAN: Relasi Arsip Digital
  archives    Archive[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id             String         @id @default(uuid())
  orderId        String
  productId      String
  qty            Int
  specifications Json           
  fileUrl        String?        
  subtotal       Float

  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id])
  productionJob  ProductionJob? 

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Payment {
  id        String        @id @default(uuid())
  orderId   String        @unique
  amount    Float
  method    String?       
  status    PaymentStatus @default(PENDING)
  proofUrl  String?       
  
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

// TAMBAHAN: Modul Mesin Cetak (Sesuai proposal "alokasi mesin cetak")
model Machine {
  id             String          @id @default(uuid())
  name           String
  status         MachineStatus   @default(AVAILABLE)
  productionJobs ProductionJob[]
  createdAt      DateTime        @default(now())
}

// 5. PRODUKSI & QUALITY CONTROL (QC)
model ProductionJob {
  id          String           @id @default(uuid())
  orderItemId String           @unique
  operatorId  String?          
  status      ProductionStatus @default(QUEUE)
  
  // PERUBAHAN: machineName String? diganti jadi relasi ke model Machine
  machineId   String?
  machine     Machine?         @relation(fields: [machineId], references: [id])
  
  notes       String?          

  orderItem   OrderItem        @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  operator    User?            @relation("OperatorJobs", fields: [operatorId], references: [id])
  qcRecord    QualityControl?

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model QualityControl {
  id              String        @id @default(uuid())
  productionJobId String        @unique
  inspectorId     String
  status          QCStatus
  notes           String?       

  productionJob   ProductionJob @relation(fields: [productionJobId], references: [id], onDelete: Cascade)
  inspector       User          @relation("QCInspector", fields: [inspectorId], references: [id])

  checkedAt       DateTime      @default(now())
}

// 6. SISTEM NOTIFIKASI & ARSIP
model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  linkUrl   String?  

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// TAMBAHAN: Modul Arsip Manajemen (Sesuai Bab 2.1 proposal)
model Archive {
  id          String   @id @default(uuid())
  orderId     String
  documentUrl String   // Link PDF Invoice, SPK, atau Laporan Akhir
  title       String   // e.g., "Invoice Lunas", "SPK Selesai"
  
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}